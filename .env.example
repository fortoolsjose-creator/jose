# Llave — environment template. Copy this file to `.env.local` and fill in real values.
# Get these from your Supabase dashboard: Project Settings -> API.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret — NEVER expose to the browser. Bypasses Row-Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Public site URL (auth redirects, shareable listing links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project ref (for the Supabase CLI: `supabase link --project-ref ...`)
SUPABASE_PROJECT_REF=your-project-ref

# Optional: send real email via Resend. If unset, notifications are logged to the
# server console (the app runs fine without it).
RESEND_API_KEY=
NOTIFICATIONS_FROM=Llave <onboarding@resend.dev>
